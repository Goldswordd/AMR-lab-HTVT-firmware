   1:Core/Src/main.c **** /**
   2:Core/Src/main.c ****  * @file    main.c
   3:Core/Src/main.c ****  * @brief   AMR Robot Firmware — Main application
   4:Core/Src/main.c ****  *
   5:Core/Src/main.c ****  * Control architecture:
   6:Core/Src/main.c ****  *   SysTick 1kHz → control_flag every 5ms (200 Hz)
   7:Core/Src/main.c ****  *   Main loop: if (control_flag) → Robot_Update() [all PID + sensors]
   8:Core/Src/main.c ****  *              uart_comm_process() → parse commands from Pi
   9:Core/Src/main.c ****  *
  10:Core/Src/main.c ****  * Startup sequence:
  11:Core/Src/main.c ****  *   1. Clock 72 MHz
  12:Core/Src/main.c ****  *   2. Init peripherals
  13:Core/Src/main.c ****  *   3. Calibrate gyro (~2 sec, must be stationary!)
  14:Core/Src/main.c ****  *   4. Enter main loop
  15:Core/Src/main.c ****  */
  16:Core/Src/main.c **** #include "main.h"
  17:Core/Src/main.c **** #include "encoder.h"
  18:Core/Src/main.c **** #include "motor.h"
  19:Core/Src/main.c **** #include "mpu6050.h"
  20:Core/Src/main.c **** #include "pid.h"
  21:Core/Src/main.c **** #include "robot.h"
  22:Core/Src/main.c **** #include "uart_comm.h"
  23:Core/Src/main.c **** #include "usbd_cdc.h"
  24:Core/Src/main.c **** #include "usbd_cdc_if.h"
  25:Core/Src/main.c **** #include "usbd_core.h"
  26:Core/Src/main.c **** #include "usbd_desc.h"
  27:Core/Src/main.c **** 
  28:Core/Src/main.c **** /* USB Device handle */
  29:Core/Src/main.c **** USBD_HandleTypeDef hUsbDeviceFS;
  30:Core/Src/main.c **** 
  31:Core/Src/main.c **** /* From stm32f1xx_it.c */
  32:Core/Src/main.c **** extern volatile uint8_t control_flag;
  33:Core/Src/main.c **** 
