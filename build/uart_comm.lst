   1:Core/Src/uart_comm.c **** /**
   2:Core/Src/uart_comm.c ****  * @file    uart_comm.c
   3:Core/Src/uart_comm.c ****  * @brief   Communication module — USB CDC (Virtual COM Port)
   4:Core/Src/uart_comm.c ****  *
   5:Core/Src/uart_comm.c ****  * Protocol:
   6:Core/Src/uart_comm.c ****  *   RX: "$CMD,linear,angular\n"  → cmd_vel
   7:Core/Src/uart_comm.c ****  *       "$ROT,angle,speed\n"     → rotate in place
   8:Core/Src/uart_comm.c ****  *       "$FWD,speed\n"           → go straight
   9:Core/Src/uart_comm.c ****  *       "$STP\n"                 → stop
  10:Core/Src/uart_comm.c ****  *       "$QRY\n"                 → request odometry
  11:Core/Src/uart_comm.c ****  *       "$PID,Kp,Ki,Kd\n"       → tune heading PID
  12:Core/Src/uart_comm.c ****  *
  13:Core/Src/uart_comm.c ****  *   TX: "$ODO,heading,enc_l,enc_r,spd_l,spd_r\n"
  14:Core/Src/uart_comm.c ****  */
  15:Core/Src/uart_comm.c **** #include "uart_comm.h"
  16:Core/Src/uart_comm.c **** #include "main.h"
  17:Core/Src/uart_comm.c **** #include "usbd_cdc_if.h"
  18:Core/Src/uart_comm.c **** #include <stdio.h>
