   1:Core/Src/usbd_cdc_if.c **** /**
   2:Core/Src/usbd_cdc_if.c ****  * @file    usbd_cdc_if.c
   3:Core/Src/usbd_cdc_if.c ****  * @brief   USB CDC interface — based on ST official template
   4:Core/Src/usbd_cdc_if.c ****  *
   5:Core/Src/usbd_cdc_if.c ****  * Provides RX/TX buffer management for USB Virtual COM Port.
   6:Core/Src/usbd_cdc_if.c ****  * Follows the USBD_CDC_ItfTypeDef interface (5 callbacks).
   7:Core/Src/usbd_cdc_if.c ****  */
   8:Core/Src/usbd_cdc_if.c **** #include "usbd_cdc_if.h"
   9:Core/Src/usbd_cdc_if.c **** #include <string.h>
  10:Core/Src/usbd_cdc_if.c **** 
  11:Core/Src/usbd_cdc_if.c **** /* ========================== Buffers ====================================== */
  12:Core/Src/usbd_cdc_if.c **** #define APP_RX_DATA_SIZE 256
  13:Core/Src/usbd_cdc_if.c **** #define APP_TX_DATA_SIZE 256
  14:Core/Src/usbd_cdc_if.c **** 
  15:Core/Src/usbd_cdc_if.c **** static uint8_t UserRxBufferFS[APP_RX_DATA_SIZE];
  16:Core/Src/usbd_cdc_if.c **** static uint8_t UserTxBufferFS[APP_TX_DATA_SIZE];
  17:Core/Src/usbd_cdc_if.c **** 
  18:Core/Src/usbd_cdc_if.c **** /* RX state — set by interrupt callback, polled by main loop */
  19:Core/Src/usbd_cdc_if.c **** static volatile uint32_t rx_data_len = 0;
  20:Core/Src/usbd_cdc_if.c **** static volatile uint8_t rx_data_ready = 0;
  21:Core/Src/usbd_cdc_if.c **** static volatile uint8_t cdc_initialized = 0;
  22:Core/Src/usbd_cdc_if.c **** 
  23:Core/Src/usbd_cdc_if.c **** extern USBD_HandleTypeDef hUsbDeviceFS;
  24:Core/Src/usbd_cdc_if.c **** 
  25:Core/Src/usbd_cdc_if.c **** /* Line coding: 115200 baud, 8N1 */
  26:Core/Src/usbd_cdc_if.c **** static USBD_CDC_LineCodingTypeDef LineCoding = {
  27:Core/Src/usbd_cdc_if.c ****     .bitrate = 115200,
  28:Core/Src/usbd_cdc_if.c ****     .format = 0x00,     /* 1 stop bit */
  29:Core/Src/usbd_cdc_if.c ****     .paritytype = 0x00, /* None */
  30:Core/Src/usbd_cdc_if.c ****     .datatype = 0x08    /* 8 bits */
  31:Core/Src/usbd_cdc_if.c **** };
  32:Core/Src/usbd_cdc_if.c **** 
  33:Core/Src/usbd_cdc_if.c **** /* ========================== CDC Interface Callbacks ====================== */
