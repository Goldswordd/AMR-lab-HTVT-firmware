 240:Core/Src/robot.c ****         angle_diff(robot.rotation_target, robot.imu.heading_deg);
 241:Core/Src/robot.c ****     static int settle_count = 0;
 242:Core/Src/robot.c **** 
 243:Core/Src/robot.c ****     if (fabsf(heading_error) < ROTATION_TOLERANCE_DEG) {
 244:Core/Src/robot.c ****       settle_count++;
 245:Core/Src/robot.c ****       if (settle_count >= ROTATION_SETTLE_COUNT) {
 246:Core/Src/robot.c ****         /* Rotation complete */
 247:Core/Src/robot.c ****         Motor_SetSpeed(MOTOR_LEFT, 0);
 248:Core/Src/robot.c ****         Motor_SetSpeed(MOTOR_RIGHT, 0);
 249:Core/Src/robot.c ****         robot.rotation_done = 1;
 250:Core/Src/robot.c ****         robot.state = ROBOT_STATE_IDLE;
 251:Core/Src/robot.c ****         settle_count = 0;
 252:Core/Src/robot.c ****         PID_Reset(&robot.pid_heading);
 253:Core/Src/robot.c ****         PID_Reset(&robot.pid_speed_left);
 254:Core/Src/robot.c ****         PID_Reset(&robot.pid_speed_right);
 255:Core/Src/robot.c ****         break;
 256:Core/Src/robot.c ****       }
 257:Core/Src/robot.c ****     } else {
 258:Core/Src/robot.c ****       settle_count = 0;
 259:Core/Src/robot.c ****     }
 260:Core/Src/robot.c **** 
 261:Core/Src/robot.c ****     /* PID on heading error → rotation speed */
 262:Core/Src/robot.c ****     float rot_output = PID_Compute(&robot.pid_heading, 0.0f, -heading_error);
 263:Core/Src/robot.c **** 
 264:Core/Src/robot.c ****     /* Feedforward for rotation */
 265:Core/Src/robot.c ****     float ff_left = rot_output * SPEED_FF_GAIN;
 266:Core/Src/robot.c ****     float ff_right = -rot_output * SPEED_FF_GAIN;
 267:Core/Src/robot.c **** 
 268:Core/Src/robot.c ****     /* Speed PID per wheel */
 269:Core/Src/robot.c ****     float pid_left =
 270:Core/Src/robot.c ****         PID_Compute(&robot.pid_speed_left, rot_output, robot.speed_left);
 271:Core/Src/robot.c ****     float pid_right =
 272:Core/Src/robot.c ****         PID_Compute(&robot.pid_speed_right, -rot_output, robot.speed_right);
 273:Core/Src/robot.c **** 
 274:Core/Src/robot.c ****     robot.pwm_left = apply_deadzone(ff_left + pid_left);
 275:Core/Src/robot.c ****     robot.pwm_right = apply_deadzone(ff_right + pid_right);
 276:Core/Src/robot.c **** 
 277:Core/Src/robot.c ****     Motor_SetSpeed(MOTOR_LEFT, robot.pwm_left);
 278:Core/Src/robot.c ****     Motor_SetSpeed(MOTOR_RIGHT, robot.pwm_right);
 279:Core/Src/robot.c ****     break;
 280:Core/Src/robot.c ****   }
