   1:Core/Src/robot.c **** /**
   2:Core/Src/robot.c ****  * @file    robot.c
   3:Core/Src/robot.c ****  * @brief   High-level robot motion — triple PID + feedforward architecture
   4:Core/Src/robot.c ****  *
   5:Core/Src/robot.c ****  * Architecture:
   6:Core/Src/robot.c ****  *   1. HEADING PID: gyro heading → differential speed correction
   7:Core/Src/robot.c ****  *   2. LEFT SPEED PID: encoder feedback + feedforward → left PWM
   8:Core/Src/robot.c ****  *   3. RIGHT SPEED PID: encoder feedback + feedforward → right PWM
   9:Core/Src/robot.c ****  *
  10:Core/Src/robot.c ****  * Improvements v2:
  11:Core/Src/robot.c ****  *   - Low-pass filtered encoder speed (removes quantization jitter)
  12:Core/Src/robot.c ****  *   - Feedforward term (estimates base PWM from target speed)
  13:Core/Src/robot.c ****  *   - Retuned PID gains for smooth operation
  14:Core/Src/robot.c ****  *   - Dead zone compensation for motor static friction
  15:Core/Src/robot.c ****  */
  16:Core/Src/robot.c **** #include "robot.h"
  17:Core/Src/robot.c **** #include "encoder.h"
  18:Core/Src/robot.c **** #include "main.h"
  19:Core/Src/robot.c **** #include "motor.h"
  20:Core/Src/robot.c **** #include <math.h>
  21:Core/Src/robot.c **** 
  22:Core/Src/robot.c **** /* ========================== Global instance ============================= */
  23:Core/Src/robot.c **** Robot_t robot;
  24:Core/Src/robot.c **** 
  25:Core/Src/robot.c **** /* ========================== Filtered speeds ============================= */
  26:Core/Src/robot.c **** /* Low-pass filter smooths the quantized encoder readings (200Hz × low CPR
  27:Core/Src/robot.c ****  * gives steppy speed values like 0, 200, 400...). Alpha=0.15 gives ~5Hz
  28:Core/Src/robot.c ****  * bandwidth — smoother than 0.3 for low-CPR encoders. */
  29:Core/Src/robot.c **** #define SPEED_FILTER_ALPHA 0.15f /* 0.0=very smooth, 1.0=raw */
  30:Core/Src/robot.c **** static float filtered_speed_left = 0.05f;
  31:Core/Src/robot.c **** static float filtered_speed_right = 0.0f;
  32:Core/Src/robot.c **** 
ARM GAS  /tmp/ccT2cdC7.s 			page 2


  33:Core/Src/robot.c **** /* ========================== PID Default Gains =========================== */
  34:Core/Src/robot.c **** /*
  35:Core/Src/robot.c ****  * Tuning procedure:
  36:Core/Src/robot.c ****  * 1. Start with Ki=0, Kd=0
  37:Core/Src/robot.c ****  * 2. Increase Kp until oscillation, then back off 30%
  38:Core/Src/robot.c ****  * 3. Add Ki slowly until steady-state error vanishes
  39:Core/Src/robot.c ****  * 4. Kd usually not needed with feedforward — leave at 0
  40:Core/Src/robot.c ****  *
  41:Core/Src/robot.c ****  * With feedforward, PID only corrects the RESIDUAL error,
  42:Core/Src/robot.c ****  * so gains can be much lower than without feedforward.
  43:Core/Src/robot.c ****  */
  44:Core/Src/robot.c **** 
  45:Core/Src/robot.c **** /* Heading PID: error in degrees → output in ticks/s correction
  46:Core/Src/robot.c ****  * Stronger than before to quickly correct drift from motor asymmetry */
  47:Core/Src/robot.c **** #define HEADING_KP 4.0f        /* Aggressive to fight wheel asymmetry */
  48:Core/Src/robot.c **** #define HEADING_KI 0.3f        /* Faster steady-state heading correction */
  49:Core/Src/robot.c **** #define HEADING_KD 0.02f       /* Light damping — reduce heading oscillation */
  50:Core/Src/robot.c **** #define HEADING_OUT_MAX 150.0f /* Max differential correction (ticks/s) */
  51:Core/Src/robot.c **** 
  52:Core/Src/robot.c **** /* Speed PID: error in ticks/s → output in PWM units (0..1000)
  53:Core/Src/robot.c ****  * Note: feedforward handles ~80% of the output, PID only corrects residual.
  54:Core/Src/robot.c ****  * Ki reduced from 1.5 to 0.5 to prevent integral windup oscillation. */
  55:Core/Src/robot.c **** #define SPEED_KP 0.5f
  56:Core/Src/robot.c **** #define SPEED_KI 0.5f
  57:Core/Src/robot.c **** #define SPEED_KD 0.0f /* Disabled — feedforward + LP filter is enough */
  58:Core/Src/robot.c **** #define SPEED_OUT_MAX                                                          \
  59:Core/Src/robot.c ****   400.0f /* PID correction range (feedforward adds the rest) */
  60:Core/Src/robot.c **** 
  61:Core/Src/robot.c **** /* Feedforward: maps target speed (ticks/s) directly to approximate PWM.
  62:Core/Src/robot.c ****  * Measured empirically: at PWM=300, motor typically runs ~200 ticks/s.
  63:Core/Src/robot.c ****  * So gain ≈ 300/200 = 1.5. Adjust based on your motors! */
  64:Core/Src/robot.c **** #define SPEED_FF_GAIN 1.5f /* PWM per (tick/s) — default for both wheels */
  65:Core/Src/robot.c **** #define MOTOR_MIN_PWM 60   /* Minimum PWM to overcome static friction */
  66:Core/Src/robot.c **** 
  67:Core/Src/robot.c **** /* Per-wheel feedforward gains — tunable via $BIAS command to compensate
  68:Core/Src/robot.c ****  * for motor asymmetry (different friction, winding resistance, etc.) */
  69:Core/Src/robot.c **** static float ff_gain_left = SPEED_FF_GAIN;
  70:Core/Src/robot.c **** static float ff_gain_right = SPEED_FF_GAIN;
  71:Core/Src/robot.c **** 
  72:Core/Src/robot.c **** /* Speed ramp: smooth acceleration instead of instant speed jump.
  73:Core/Src/robot.c ****  * 600 ticks/s² means reaching 300 ticks/s takes 0.5 seconds. */
  74:Core/Src/robot.c **** #define SPEED_RAMP_RATE 600.0f /* ticks/s per second */
  75:Core/Src/robot.c **** static float ramped_speed = 0.0f;
  76:Core/Src/robot.c **** 
  77:Core/Src/robot.c **** /* Rotation tolerance */
  78:Core/Src/robot.c **** #define ROTATION_TOLERANCE_DEG 1.5f
  79:Core/Src/robot.c **** #define ROTATION_SETTLE_COUNT 20 /* 20 loops × 5ms = 100ms settled */
  80:Core/Src/robot.c **** 
