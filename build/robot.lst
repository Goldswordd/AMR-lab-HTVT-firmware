 320:Core/Src/robot.c **** void Robot_SetVelocity(float linear_speed, float angular_vel) {
 321:Core/Src/robot.c ****   if (fabsf(linear_speed) < 0.1f && fabsf(angular_vel) < 0.1f) {
 322:Core/Src/robot.c ****     Robot_Stop();
 323:Core/Src/robot.c ****     return;
 324:Core/Src/robot.c ****   }
 325:Core/Src/robot.c **** 
 326:Core/Src/robot.c ****   robot.target_speed = linear_speed;
 327:Core/Src/robot.c ****   robot.target_angular_vel = angular_vel;
 328:Core/Src/robot.c **** 
 329:Core/Src/robot.c ****   /* Update heading target continuously based on angular velocity */
 330:Core/Src/robot.c ****   robot.target_heading += angular_vel * CONTROL_DT;
 331:Core/Src/robot.c ****   while (robot.target_heading > 180.0f)
 332:Core/Src/robot.c ****     robot.target_heading -= 360.0f;
 333:Core/Src/robot.c ****   while (robot.target_heading < -180.0f)
 334:Core/Src/robot.c ****     robot.target_heading += 360.0f;
 335:Core/Src/robot.c **** 
 336:Core/Src/robot.c ****   if (robot.state != ROBOT_STATE_MOVING) {
 337:Core/Src/robot.c ****     robot.state = ROBOT_STATE_MOVING;
 338:Core/Src/robot.c ****     PID_Reset(&robot.pid_heading);
 339:Core/Src/robot.c ****     PID_Reset(&robot.pid_speed_left);
 340:Core/Src/robot.c ****     PID_Reset(&robot.pid_speed_right);
 341:Core/Src/robot.c ****   }
 342:Core/Src/robot.c **** }
