  21:Core/Src/usbd_desc.c ****     0x00,
  22:Core/Src/usbd_desc.c ****     0x02,             /* bcdUSB = 2.00 */
  23:Core/Src/usbd_desc.c ****     0x02,             /* bDeviceClass: CDC */
  24:Core/Src/usbd_desc.c ****     0x02,             /* bDeviceSubClass */
  25:Core/Src/usbd_desc.c ****     0x00,             /* bDeviceProtocol */
  26:Core/Src/usbd_desc.c ****     USB_MAX_EP0_SIZE, /* bMaxPacketSize */
  27:Core/Src/usbd_desc.c ****     LOBYTE(USBD_VID),
  28:Core/Src/usbd_desc.c ****     HIBYTE(USBD_VID),
  29:Core/Src/usbd_desc.c ****     LOBYTE(USBD_PID_FS),
  30:Core/Src/usbd_desc.c ****     HIBYTE(USBD_PID_FS),
  31:Core/Src/usbd_desc.c ****     0x00,
  32:Core/Src/usbd_desc.c ****     0x02,                      /* bcdDevice = 2.00 */
