  17:Core/Src/usbd_desc.c **** /* USB Standard Device Descriptor */
  18:Core/Src/usbd_desc.c **** static uint8_t USBD_FS_DeviceDesc[USB_LEN_DEV_DESC] = {
  19:Core/Src/usbd_desc.c ****     0x12,                 /* bLength */
