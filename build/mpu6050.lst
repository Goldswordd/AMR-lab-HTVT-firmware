   1:Core/Src/mpu6050.c **** /**
   2:Core/Src/mpu6050.c ****  * @file    mpu6050.c
   3:Core/Src/mpu6050.c ****  * @brief   MPU6050 I2C driver — gyro Z integration for heading
   4:Core/Src/mpu6050.c ****  *
   5:Core/Src/mpu6050.c ****  * KEY DESIGN DECISIONS for accurate heading:
   6:Core/Src/mpu6050.c ****  *   1. Calibrate bias at startup (average 2000 stationary samples)
   7:Core/Src/mpu6050.c ****  *   2. Use ±250°/s range for maximum sensitivity (131 LSB/°/s)
   8:Core/Src/mpu6050.c ****  *   3. DLPF at 42 Hz to filter mechanical vibration
   9:Core/Src/mpu6050.c ****  *   4. Fixed-rate integration (5ms) — NEVER use variable dt
  10:Core/Src/mpu6050.c ****  *   5. Dead zone: ignore |rate| < 0.15°/s to prevent noise drift
  11:Core/Src/mpu6050.c ****  */
  12:Core/Src/mpu6050.c **** #include "mpu6050.h"
  13:Core/Src/mpu6050.c **** #include "main.h"
  14:Core/Src/mpu6050.c **** #include <math.h>
  15:Core/Src/mpu6050.c **** 
  16:Core/Src/mpu6050.c **** /* Dead zone threshold — below this, gyro reads as zero */
  17:Core/Src/mpu6050.c **** #define GYRO_DEADZONE_DPS 0.20f
  18:Core/Src/mpu6050.c **** 
  19:Core/Src/mpu6050.c **** /* Online recalibration: exponential moving average rate */
  20:Core/Src/mpu6050.c **** #define RECAL_ALPHA                                                            \
  21:Core/Src/mpu6050.c ****   0.001f /* Very slow update — ~5 sec time constant at 200Hz */
  22:Core/Src/mpu6050.c **** 
  23:Core/Src/mpu6050.c **** /* ========================== Private helpers ============================= */
  24:Core/Src/mpu6050.c **** 
